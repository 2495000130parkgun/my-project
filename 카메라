using UnityEngine;

[RequireComponent(typeof(Camera))]
public class HighQualityCameraController : MonoBehaviour
{
    public Transform target; 
    public Vector3 offset = new Vector3(0, 0, -10f); // 카메라 오프셋
    public float followSpeed = 5f;

    private Camera cam;

    void Awake()
    {
        cam = GetComponent<Camera>();

        
        cam.backgroundColor = Color.cyan;

      
        QualitySettings.antiAliasing = 4; // 
        QualitySettings.vSyncCount = 1;

        
        cam.allowHDR = true;
        cam.allowMSAA = true;
        cam.orthographic = true; 
        cam.orthographicSize = 5f;
    }

    void FixedUpdate()
    {
        if (target == null) return;

        Vector3 desiredPos = target.position + offset;
        desiredPos.z = offset.z; 
        transform.position = Vector3.Lerp(transform.position, desiredPos, followSpeed * Time.fixedDeltaTime);
    }
}
